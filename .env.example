# Meld White-Label API credentials (get from dashboard.meld.io > Developer > API Keys)
MELD_API_KEY=your_meld_api_key_here
MELD_API_BASE_URL=https://api-sb.meld.io
MELD_API_VERSION=2026-02-03
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Gemini-powered support chat (Google AI Studio → API key). If unset, chat uses the built-in FAQ replies.
GEMINI_API_KEY=
# Optional override (default: gemini-1.5-flash). Set gemini-2.0-flash if your project supports it.
GEMINI_MODEL=
